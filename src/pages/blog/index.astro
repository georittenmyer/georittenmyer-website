---
import Base from '../../layouts/Base.astro';

// Fetch all .md files from the blog folder
const modules = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(modules);

// Sort newest first
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Base
  title="Blog — Geo Rittenmyer"
  description="Behind the scenes, travel notes, and stories from photographer Geo Rittenmyer."
>
  <div class="blog-page">
    <header class="blog-header">
      <h1>Blog</h1>
      <p>Behind the scenes, travel notes, and stories from the work.</p>
    </header>

    <div class="post-grid">
      {sorted.map((post) => {
        const { title, date, cover, coverPosition = 'center' } = post.frontmatter;
        const slug = post.url;
        const d = new Date(date);
        const formatted = `${String(d.getMonth() + 1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}/${d.getFullYear()}`;

        return (
          <a href={slug} class="post-card">
            <div class="post-mat">
              {cover && (
                <div class="post-thumb">
                  <img src={cover} alt={title} loading="lazy" style={`object-position: ${coverPosition}`} />
                </div>
              )}
            </div>
            <div class="post-info">
              <h2>{title}</h2>
              <time datetime={date}>{formatted}</time>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .blog-page {
    max-width: 1500px;
    margin: 0 auto;
    padding: calc(var(--nav-h) + 48px) 32px 80px;
  }

  .blog-header {
    margin-bottom: 56px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding-bottom: 32px;
  }

  .blog-header h1 {
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .blog-header p {
    font-size: 18px;
    color: var(--ink-soft);
    font-style: italic;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .post-card {
    text-decoration: none;
    color: var(--ink);
    display: block;
    background: #f7f6f2;
    transition: transform 0.25s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
  }

  .post-mat {
    padding: 10px 10px 0;
  }

  .post-thumb {
    overflow: hidden;
    aspect-ratio: 3/2;
    position: relative;
  }

  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .post-card:hover .post-thumb img { transform: scale(1.03); }


  .post-info {
    position: relative;
    padding: 0px 10px 16px;
    text-align: center;
  }

  .post-info h2 {
    font-size: 26px;
    font-weight: 400;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
    transform: translateY(-4px);
  }

  .post-info time {
    position: absolute;
    bottom: 10px;
    right: 10px;
    font-family: 'cabin-sketch', sans-serif;
    font-size: 11px;
    color: var(--accent);
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .post-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  @media (max-width: 768px) {
    .blog-page { padding: calc(var(--nav-h) + 32px) 20px 60px; }

    .post-info time {
      position: static;
      display: block;
      font-size: 10px;
      color: var(--ink-soft);
      margin-top: 8px;
      white-space: normal;
    }
  }
</style>
