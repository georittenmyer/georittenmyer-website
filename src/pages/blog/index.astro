---
import Base from '../../layouts/Base.astro';

// Fetch all .md files from the blog folder
const posts = await Astro.glob('./*.md');

// Sort newest first
const sorted = posts.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<Base
  title="Blog — Geo Rittenmyer"
  description="Behind the scenes, travel notes, and stories from photographer Geo Rittenmyer."
>
  <div class="blog-page">
    <header class="blog-header">
      <h1>Blog</h1>
      <p>Behind the scenes, travel notes, and stories from the work.</p>
    </header>

    <div class="post-grid">
      {sorted.map((post) => {
        const { title, date, cover, description, coverPosition = 'center' } = post.frontmatter;
        const slug = post.url;
        const formatted = new Date(date).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        });

        return (
          <a href={slug} class="post-card">
            {cover && (
              <div class="post-thumb">
                <img src={cover} alt={title} loading="lazy" style={`object-position: ${coverPosition}`} />
              </div>
            )}
            <div class="post-info">
              <time datetime={date}>{formatted}</time>
              <h2>{title}</h2>
              {description && <p>{description}</p>}
              <span class="read-more">Read More →</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .blog-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: calc(var(--nav-h) + 48px) 32px 80px;
  }

  .blog-header {
    margin-bottom: 56px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding-bottom: 32px;
  }

  .blog-header h1 {
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .blog-header p {
    font-size: 18px;
    color: var(--ink-soft);
    font-style: italic;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 64px 48px;
  }

  .post-card {
    text-decoration: none;
    color: var(--ink);
    display: block;
  }

  .post-thumb {
    overflow: hidden;
    margin-bottom: 20px;
    aspect-ratio: 3/2;
  }

  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .post-card:hover .post-thumb img { transform: scale(1.04); }

  .post-info time {
    display: block;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 8px;
  }

  .post-info h2 {
    font-size: 28px;
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .post-info p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 14px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .post-card:hover .read-more { color: var(--ink); }

  @media (max-width: 768px) {
    .blog-page { padding: calc(var(--nav-h) + 32px) 20px 60px; }
    .post-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
