---

<Base
    title="Kodachrome — Geo Rittenmyer"
    description="A film photography project shot on Kodachrome by Geo Rittenmyer."
>
    <div class="koda-page">

        <div class="koda-header">
            <h1>Kodachrome</h1>
            <p class="koda-desc">Through the late 60s, 70s, and into the early 80s, my grandfather carried a few cameras with him, most often a Pentax SE, and photographed his travels for both work and family trips. When he returned home, he would assemble his favorites into Kodak slide trays and invite friends and family over for an evening slideshow to share the trip.</p>
            <p class="koda-desc">I have preserved boxes of those slides, and whenever I find a little free time I pull some out and scan a few. Many of them remain small mysteries because I often have no idea where the photo was taken.</p>
        </div>

        <div class="koda-grid" id="kodaGrid">
            {images.map((img, i) => (
                <button class="koda-cell" data-index={i} aria-label={`Photo ${i + 1}`}>
                    <picture>
                        <source srcset={img.avif} type="image/avif" />
                        <img src={img.jpg} alt={`Kodachrome ${i + 1}`} loading={i < 9 ? 'eager' : 'lazy'} />
                    </picture>
                </button>
            ))}
        </div>

    </div>

    <!-- Zoom overlay -->
    <div id="kodaZoom" class="koda-zoom" aria-hidden="true">
        <button class="koda-zoom-close lb-key-btn" id="kodaZoomClose" aria-label="Close">ESC</button>
        <button class="koda-zoom-prev lb-key-btn" id="kodaZoomPrev" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 4 6 9 11 14"/></svg>
        </button>
        <button class="koda-zoom-next lb-key-btn" id="kodaZoomNext" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 12 9 7 14"/></svg>
        </button>
        <div class="koda-zoom-wrap" id="kodaZoomWrap">
            <img id="kodaZoomImg" src="" alt="" />
        </div>
        <div class="koda-counter" id="kodaCounter"></div>
    </div>
</Base>

<script is:inline>
    var allImages = Array.from(document.querySelectorAll('#kodaGrid source[type="image/avif"]')).map(function(source) {
        return source.srcset;
    }).concat(Array.from(document.querySelectorAll('#kodaGrid img')).map(function(img) {
        return img.src;
    }));

    var zoom      = document.getElementById('kodaZoom');
    var zoomImg   = document.getElementById('kodaZoomImg');
    var zoomWrap  = document.getElementById('kodaZoomWrap');
    var counter   = document.getElementById('kodaCounter');
    var btnClose  = document.getElementById('kodaZoomClose');
    var btnPrev   = document.getElementById('kodaZoomPrev');
    var btnNext   = document.getElementById('kodaZoomNext');
    var current   = 0;

    function openZoom(index) {
        current = index;
        showImage();
        zoom.classList.add('open');
        zoom.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closeZoom() {
        zoom.classList.remove('open');
        zoom.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    function showImage() {
        zoomImg.src = allImages[current];
        counter.textContent = (current + 1) + ' / ' + allImages.length;
    }

    function prev() { current = (current - 1 + allImages.length) % allImages.length; showImage(); }
    function next() { current = (current + 1) % allImages.length; showImage(); }

    document.querySelectorAll('.koda-cell').forEach(function(btn) {
        btn.addEventListener('click', function() {
            openZoom(parseInt(btn.dataset.index));
        });
    });

    btnClose.addEventListener('click', closeZoom);
    btnPrev.addEventListener('click', prev);
    btnNext.addEventListener('click', next);

    zoom.addEventListener('click', function(e) {
        if (e.target === zoom || e.target === zoomWrap) closeZoom();
    });

    document.addEventListener('keydown', function(e) {
        if (!zoom.classList.contains('open')) return;
        if (e.key === 'Escape')      closeZoom();
        if (e.key === 'ArrowLeft')   prev();
        if (e.key === 'ArrowRight')  next();
    });
</script>

<style>
    .koda-page {
        padding: calc(var(--nav-h) + 48px) 6% 6%;
    }

    /* ── Header ── */
    .koda-header {
        margin-bottom: 48px;
    }

    .koda-header h1 {
        font-family: sketchnote-square, sans-serif;
        font-size: clamp(28px, 3vw, 48px);
        font-weight: 400;
        letter-spacing: 0.02em;
        line-height: 1.1;
        margin-bottom: 16px;
    }

    .koda-desc {
        font-size: 17px;
        line-height: 1.8;
        color: var(--ink-soft);
        max-width: 960px;
    }

    /* ── Grid ── */
    .koda-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .koda-cell {
        display: block;
        padding: 0;
        border: none;
        background: none;
        cursor: zoom-in;
        aspect-ratio: 3 / 2;
        overflow: hidden;
    }

    .koda-cell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.2s;
    }

    .koda-cell:hover img {
        opacity: 0.85;
    }

    /* ── Zoom overlay ── */
    .koda-zoom {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--bg);
        z-index: 500;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .koda-zoom.open {
        display: flex;
    }

    .koda-zoom-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        padding: 120px;
        box-sizing: border-box;
    }

    .koda-zoom-wrap img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
        user-select: none;
    }

    .koda-zoom-close {
        position: absolute;
        top: 24px;
        left: 6%;
        font-size: 13px;
        letter-spacing: 0.12em;
        padding: 7px 12px;
        z-index: 502;
    }

    .koda-zoom-prev,
    .koda-zoom-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        padding: 12px;
        z-index: 502;
    }

    .koda-zoom-prev:hover,
    .koda-zoom-next:hover {
        transform: translateY(calc(-50% + 0.3px));
    }

    .koda-zoom-prev { left: 32px; }
    .koda-zoom-next { right: 32px; }

    .koda-counter {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 12px;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
        white-space: nowrap;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .koda-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .koda-zoom-wrap {
            padding: 80px 24px;
        }

        .koda-zoom-prev { left: 12px; }
        .koda-zoom-next { right: 12px; }
    }

    @media (max-width: 640px) {
        .koda-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
