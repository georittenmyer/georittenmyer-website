---
import Base from '../../layouts/Base.astro';

const BASE = 'https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/';

const projects = [
  { id: 'bali', title: 'Bali', images: [
    '1367605698473-X98D0VGOFJUTPWST6QRY/Bali-1.jpg',
    '1367605725143-XYQYFHSXTPKXMRCKYCMV/Bali-2.jpg',
    '1367605726482-PYPCM0D66GNWJIEXQ048/Bali-3.jpg',
    '1367605736984-337FUFRHIKI1UU3YUWFY/Bali-4.jpg',
    '1367607373325-F3ZW125TCPW9GF5VQ91P/20101112_0364.jpg',
    '1367607365632-9MD07G2U8Z0AJNQF272K/20101112_1013.jpg',
    '1367605769752-MT6V5MF46E1XK07MS2IO/Bali-7.jpg',
    '1367605761627-UL8N0OTDDQQIFH3FC3Q0/Bali-8.jpg',
    '1367605784689-TEARD7OCURJLX6ZV0K9S/Bali-9.jpg',
    '1367605778607-WEE4P5B8OTYIGBW2BG1Y/Bali-10.jpg',
    '1367605794276-AAJS3S7WYMRL3VENM3BT/Bali-11.jpg',
    '1367605796305-0PJVUGG48QTEX5VYOHKC/Bali-12.jpg',
    '1367605817719-5BOOBR0RP2TXKUBJ05QL/Bali-13.jpg',
    '1367605817800-3MF9DS2VPPA6M1AA0A6J/Bali-14.jpg',
    '1367605838929-1ZRV74JLCT38M4CQO7S3/Bali-15.jpg',
    '1367605836344-2TBD7J2VTE16YPI2L6RZ/Bali-16.jpg',
    '1367605850102-H3I3MCJEXT8SVFSBIOYH/Bali-17.jpg',
    '1367605849583-ES2831KCMFSO6K35QK0E/Bali-18.jpg',
    '1367605860855-4TZY2MONNNJLF1XQCAHX/Bali-19.jpg',
    '1367605860070-VMENHJBXM7NURM2X5PVV/Bali-20.jpg',
  ]},
];

const projectData = projects.map(p => ({
  ...p,
  images: p.images.map(img => BASE + img),
  cover: BASE + p.images[0],
}));
---

<Base title="Bali — Geo Rittenmyer">
  <div class="masonry" id="baliGrid">
    {projectData.map((p, i) => (
      <div class="card" style={`animation-delay: ${i * 40}ms`} data-images={JSON.stringify(p.images)} data-title={p.title}>
        <img src={p.cover} alt={p.title} loading="eager" />
        <div class="card-label"><span>{p.title}</span></div>
      </div>
    ))}
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('.card').forEach(card => {
    const images: string[] = JSON.parse(card.dataset.images || '[]');
    if (images.length > 1) {
      const img = card.querySelector('img') as HTMLImageElement;
      img.src = images[Math.floor(Math.random() * images.length)];
    }
  });
</script>
