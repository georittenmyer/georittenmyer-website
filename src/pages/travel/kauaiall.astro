---

<Base
    title="Kauai — Geo Rittenmyer"
    description="A complete collection of photographs from Kauai, Hawaii by Geo Rittenmyer."
>
    <div class="kauai-page">

        <div class="kauai-header">
            <h1>Kauai</h1>
            <p class="kauai-desc">Title and description coming soon.</p>
        </div>

        <div class="kauai-grid" id="kauaiGrid">
            {images.map((src, i) => (
                <button class="kauai-cell" data-index={i} aria-label={`Photo ${i + 1}`}>
                    <img src={src} alt={`Kauai ${i + 1}`} loading={i < 9 ? 'eager' : 'lazy'} />
                </button>
            ))}
        </div>

    </div>

    <!-- Zoom overlay -->
    <div id="kauaiZoom" class="kauai-zoom" aria-hidden="true">
        <button class="kauai-zoom-close lb-key-btn" id="kauaiZoomClose" aria-label="Close">ESC</button>
        <button class="kauai-zoom-prev lb-key-btn" id="kauaiZoomPrev" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 4 6 9 11 14"/></svg>
        </button>
        <button class="kauai-zoom-next lb-key-btn" id="kauaiZoomNext" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 12 9 7 14"/></svg>
        </button>
        <div class="kauai-zoom-wrap" id="kauaiZoomWrap">
            <img id="kauaiZoomImg" src="" alt="" />
        </div>
        <div class="kauai-counter" id="kauaiCounter"></div>
    </div>
</Base>

<script is:inline>
    var allImages = Array.from(document.querySelectorAll('#kauaiGrid img')).map(function(img) {
        return img.src;
    });

    var zoom     = document.getElementById('kauaiZoom');
    var zoomImg  = document.getElementById('kauaiZoomImg');
    var zoomWrap = document.getElementById('kauaiZoomWrap');
    var counter  = document.getElementById('kauaiCounter');
    var btnClose = document.getElementById('kauaiZoomClose');
    var btnPrev  = document.getElementById('kauaiZoomPrev');
    var btnNext  = document.getElementById('kauaiZoomNext');
    var current  = 0;

    function openZoom(index) {
        current = index;
        showImage();
        zoom.classList.add('open');
        zoom.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closeZoom() {
        zoom.classList.remove('open');
        zoom.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    function showImage() {
        zoomImg.src = allImages[current];
        counter.textContent = (current + 1) + ' / ' + allImages.length;
    }

    function prev() { current = (current - 1 + allImages.length) % allImages.length; showImage(); }
    function next() { current = (current + 1) % allImages.length; showImage(); }

    document.querySelectorAll('.kauai-cell').forEach(function(btn) {
        btn.addEventListener('click', function() {
            openZoom(parseInt(btn.dataset.index));
        });
    });

    btnClose.addEventListener('click', closeZoom);
    btnPrev.addEventListener('click', prev);
    btnNext.addEventListener('click', next);

    zoom.addEventListener('click', function(e) {
        if (e.target === zoom || e.target === zoomWrap) closeZoom();
    });

    document.addEventListener('keydown', function(e) {
        if (!zoom.classList.contains('open')) return;
        if (e.key === 'Escape')      closeZoom();
        if (e.key === 'ArrowLeft')   prev();
        if (e.key === 'ArrowRight')  next();
    });
</script>

<style>
    .kauai-page {
        padding: calc(var(--nav-h) + 48px) 6% 6%;
    }

    .kauai-header {
        margin-bottom: 48px;
    }

    .kauai-header h1 {
        font-family: sketchnote-square, sans-serif;
        font-size: clamp(28px, 3vw, 48px);
        font-weight: 400;
        letter-spacing: 0.02em;
        line-height: 1.1;
        margin-bottom: 16px;
    }

    .kauai-desc {
        font-size: 17px;
        line-height: 1.8;
        color: var(--ink-soft);
        max-width: 960px;
    }

    .kauai-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .kauai-cell {
        display: block;
        padding: 0;
        border: none;
        background: none;
        cursor: zoom-in;
        aspect-ratio: 3 / 2;
        overflow: hidden;
    }

    .kauai-cell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.2s;
    }

    .kauai-cell:hover img {
        opacity: 0.85;
    }

    .kauai-zoom {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--bg);
        z-index: 500;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .kauai-zoom.open {
        display: flex;
    }

    .kauai-zoom-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        padding: 120px;
        box-sizing: border-box;
    }

    .kauai-zoom-wrap img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
        user-select: none;
    }

    .kauai-zoom-close {
        position: absolute;
        top: 24px;
        left: 6%;
        font-size: 13px;
        letter-spacing: 0.12em;
        padding: 7px 12px;
        z-index: 502;
    }

    .kauai-zoom-prev,
    .kauai-zoom-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        padding: 12px;
        z-index: 502;
    }

    .kauai-zoom-prev:hover,
    .kauai-zoom-next:hover {
        transform: translateY(calc(-50% + 0.3px));
    }

    .kauai-zoom-prev { left: 32px; }
    .kauai-zoom-next { right: 32px; }

    .kauai-counter {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 12px;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
        white-space: nowrap;
    }

    @media (max-width: 768px) {
        .kauai-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .kauai-zoom-wrap { padding: 80px 24px; }
        .kauai-zoom-prev { left: 12px; }
        .kauai-zoom-next { right: 12px; }
    }

    @media (max-width: 480px) {
        .kauai-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
