---
import Base from '../../layouts/Base.astro';

const BASE = 'https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/';

const projects = [
  { id: 'oahu', title: 'Oahu', images: [
    '1368169224516-VL7Y75GV4DJTKR58VM34/20130505_0148.jpg',
    '1368169240350-W36HJNIQOJ46ZTD0INDJ/20130505_0164.jpg',
    '1368169219931-IUE4AW8Q54KIFN5AWQX0/20130505_0160.jpg',
    '1368169235319-4JQ2GJOWE0KAMF0HDJ2R/20130505_0234.jpg',
    '1368169259568-XN8H5F81QXDAD5GOQXZ8/20130505_0641.jpg',
    '1368169251843-1J3KN6935NBYS8RDKEM1/20130506_0019.jpg',
    '1368169265195-64U6F9JCNU6FIFFOHJBY/20130506_0158.jpg',
    '1368169316003-LH5TEW8DXKN0O8Z1BTS7/20130507_0098.jpg',
    '1368169276197-IVSFBP2PW0HKDBJJL6EB/20130506_0349.jpg',
    '1368169280330-4GEUXR17Q0K6I78Q3CNI/20130506_0529.jpg',
    '1368991284809-EHFDAKR86ITO9KXISJ6M/20130507_0168.jpg',
    '1368169285220-O12OLEDJ6FR2T7QLTM49/20130506_0607.jpg',
    '1368169295714-L1P7K2Z5LLB7UKTOLN6F/20130506_0623.jpg',
    '1368169377414-F0MIAIQG7DRXQVNVAU5P/20130508_0064.jpg',
    '1368169315797-OTEFDRANSBZBKNZDQ02T/20130506_10019.jpg',
    '1368169344460-3C2WRS1TKIRNO5E66R3O/20130507_0117.jpg',
    '1368169377448-UM2KC827WGG14JORWC1C/20130508_0014.jpg',
    '1368169344054-FHODLM5VVRQ2QZXCF32H/20130507_0114.jpg',
    '1368169390285-GWJOHPSNJ7DSEA2JA0AD/20130508_0115.jpg',
    '1368169395393-OMURA1QTT1K301WC5SOJ/20130508_0258.jpg',
  ]},
];

const projectData = projects.map(p => ({
  ...p,
  images: p.images.map(img => BASE + img),
  cover: BASE + p.images[0],
}));
---

<Base title="Oahu — Geo Rittenmyer">
  <div class="masonry" id="oahuGrid">
    {projectData.map((p, i) => (
      <div class="card" style={`animation-delay: ${i * 40}ms`} data-images={JSON.stringify(p.images)} data-title={p.title}>
        <img src={p.cover} alt={p.title} loading="eager" />
        <div class="card-label"><span>{p.title}</span></div>
      </div>
    ))}
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('.card').forEach(card => {
    const images: string[] = JSON.parse(card.dataset.images || '[]');
    if (images.length > 1) {
      const img = card.querySelector('img') as HTMLImageElement;
      img.src = images[Math.floor(Math.random() * images.length)];
    }
  });
</script>
