const isVideo = (src: string) => src.endsWith('.mp4') || src.endsWith('.webm');

const projectData = projects.map(p => ({
  ...p,
  images: p.images.map(img => BASE + img),
  coverImages: p.images.slice(0, 3).map(img => BASE + img),
  cover: BASE + p.images[0],
}));
---

<Base
  title="Geo Rittenmyer — Seattle Commercial Photographer"
  description="Seattle-based commercial photographer specializing in editorial, brand, events, and portrait work. Clients include Disney, ESPN, NBC Universal, Amazon, and Lyft."
>
  <div class="masonry" id="mainGrid">
    {projectData.map((p, i) => (
      <div class="card" style={`animation-delay: ${i * 40}ms`} data-images={JSON.stringify(p.images)} data-cover-images={JSON.stringify(p.coverImages)} data-title={p.title}>
        {isVideo(p.cover) ? (
          <video autoplay loop muted playsinline>
            <source src={p.cover.replace('.mp4', '.webm')} type="video/webm" />
            <source src={p.cover} type="video/mp4" />
          </video>
        ) : (
          <img src={p.cover} alt={`${p.title} — commercial photography by Geo Rittenmyer`} loading={i < 4 ? 'eager' : 'lazy'} />
        )}
        <div class="card-label"><span>{p.title}</span></div>
      </div>
    ))}
  </div>
</Base>

<script>
  // Randomize gallery order on each page load
  const grid = document.getElementById('mainGrid')!;
  const cards = Array.from(grid.children);
  for (let i = cards.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    grid.appendChild(cards[j]);
    cards.splice(j, 1);
  }

  // Randomize cover on each page load (from first 3 images only), swapping element type as needed
  const isVidSrc = (s: string) => s.endsWith('.mp4') || s.endsWith('.webm');
  document.querySelectorAll<HTMLElement>('.card').forEach(card => {
    const coverImages: string[] = JSON.parse(card.dataset.coverImages || '[]');
    if (coverImages.length < 2) return;
    const src = coverImages[Math.floor(Math.random() * coverImages.length)];
    const existing = card.querySelector('img, video') as HTMLElement | null;
    if (!existing) return;
    if (isVidSrc(src)) {
      if (existing.tagName === 'VIDEO') {
        const vid = existing as HTMLVideoElement;
        vid.innerHTML = `<source src="${src.replace('.mp4', '.webm')}" type="video/webm"><source src="${src}" type="video/mp4">`;
        vid.load();
      } else {
        const vid = document.createElement('video');
        vid.autoplay = true; vid.loop = true; vid.muted = true; vid.playsInline = true;
        vid.innerHTML = `<source src="${src.replace('.mp4', '.webm')}" type="video/webm"><source src="${src}" type="video/mp4">`;
        existing.replaceWith(vid);
      }
    } else {
      if (existing.tagName === 'IMG') {
        (existing as HTMLImageElement).src = src;
      } else {
        const img = document.createElement('img');
        img.src = src;
        img.alt = `${card.dataset.title} — commercial photography by Geo Rittenmyer`;
        existing.replaceWith(img);
      }
    }
  });

  // Show title label on mobile: visible when card center is below viewport center
  function updateCardLabels() {
    const vh = window.innerHeight;
    const viewportCenter = vh / 2;
    document.querySelectorAll<HTMLElement>('.card').forEach(card => {
      const rect = card.getBoundingClientRect();
      const cardCenter = rect.top + rect.height / 2;
      const inView = rect.top < vh && cardCenter > viewportCenter - 20;
      card.classList.toggle('in-view', inView);
    });
  }

  window.addEventListener('scroll', updateCardLabels, { passive: true });
  updateCardLabels();
</script>
