---
import Base from '../layouts/Base.astro';

const clients = [
  'Sesame Street Live','NBC Universal','Reader\'s Digest','Time Magazine','SeattleMet',
  'Men\'s Journal','Sports Illustrated','ESPN Magazine','The Today Show','The Guardian',
  'Lyft','Jurassic World','AMA Supercross','Jhane Barnes','Seven New York','Ralph Lauren',
  'A&E','Voom-HD','Rainbow Media','New York Times Magazine','Cole & Weber United',
  'Washington\'s Lottery','TBWA/Chiat/Day','AARP','Feld Entertainment','Ringling Bros',
  'Disney','Marvel Universe Live','NYC Heart Gallery','Seattle Good Business Network',
];
---

<Base
  title="Info — Geo Rittenmyer"
  description="Seattle-based photographer Geo Rittenmyer — available for editorial, event, and brand work."
  ogImage="https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/0881d0f4-aa7c-40d0-b52f-6eb1364664da/20231110_0155.jpg"
>
  <div class="info-page">

    <div class="info-hero">
      <img
        class="info-portrait"
        src="https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/0881d0f4-aa7c-40d0-b52f-6eb1364664da/20231110_0155.jpg"
        alt="Geo Rittenmyer"
      />
      <div class="info-bio">
        <h2>Geo Rittenmyer</h2>
        <p class="info-tagline">Seattle photographer — editorial, events, brand</p>
        <p>I'm drawn to moments of light and narrative. Trained at Brooks Institute, I work on editorial, advertising, and live events — for clients like ESPN, Sports Illustrated, Ralph Lauren, Disney, NBC Universal, and major agencies.</p>
        <p>Currently working on a personal landscape book with essays on global affairs. Based in Seattle with a fully equipped studio.</p>
        <p>Stock imagery via <a href="https://www.gallerystock.com" target="_blank" rel="noopener">Gallery Stock</a>.</p>

        <div class="info-tags">
          <span>Editorial</span>
          <span>Events</span>
          <span>Brand</span>
          <span>Portrait</span>
          <span>Documentary</span>
        </div>

        <div class="info-contact">
          <div class="info-contact-primary">
            <a href="mailto:geo@georittenmyer.com">geo@georittenmyer.com</a>
          </div>
          <div class="info-contact-secondary">
            <a href="tel:+16465849860">(646) 584-9860</a>
            <a href="https://www.instagram.com/georittenmyer/" target="_blank" rel="noopener">@georittenmyer</a>
          </div>
          <div class="info-available">
            <span class="info-available-dot"></span>
            <span>Available for new projects</span>
          </div>
        </div>
      </div>
    </div>

    <div class="info-clients">
      <p class="info-clients-label">Selected Clients</p>
      <div class="marquee-track">
        {clients.map(c => <span>{c}</span>)}
        {clients.map(c => <span aria-hidden="true">{c}</span>)}
      </div>
    </div>

  </div>
</Base>
