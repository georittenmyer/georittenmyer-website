---
import Base from "../layouts/Base.astro";

const clients = [
    "ESPN", "Sports Illustrated", "Ralph Lauren", "Disney",
    "NBC Universal", "Time Magazine", "SeattleMet", "Men's Journal",
    "The Guardian", "Lyft", "Jurassic World", "AMA Supercross",
    "Sesame Street Live", "Ringling", "Marvel Universe Live", "AARP",
    "Feld Entertainment", "Reader's Digest", "The Today Show", "TBWA/Chiat/Day",
    "Washington's Lottery", "A&E", "New York Times Magazine", "Cole & Weber",
    "Jhane Barnes", "Seven New York", "NYC Heart Gallery", "Amazon",
];
---

<Base
    title="About — Geo Rittenmyer, Seattle Commercial Photographer"
    description="Geo Rittenmyer is a Seattle-based commercial photographer with 20+ years shooting for Disney, ESPN, NBC Universal, Amazon, Lyft, and major agencies worldwide."
>
    <div class="info-page">
        <div class="layout">

            <!-- ── PHOTO ── -->
            <div class="photo-col">
                <div class="photo-wrap">
                    <img
                        src="/images/portrait.jpg"
                        alt="Geo Rittenmyer"
                        loading="eager"
                    />
                    <p class="photo-caption">Legoland 2025</p>
                </div>

                <div class="contact-row">
                    <div class="contact-block">
                        <p class="section-label">Contact</p>
                        <div class="available-tag">
                            <span class="dot"></span>
                            Available for new projects
                        </div>
                        <a href="mailto:geo@georittenmyer.com">geo@georittenmyer.com</a>
                        <a href="tel:6465849860">(646) 584-9860</a>
                        <a href="https://instagram.com/georittenmyer" target="_blank" rel="noopener">@georittenmyer</a>
                    </div>
                    <div class="ask-col">
                        <button class="ask-btn" id="askBtn">Ask me a question</button>
                    </div>
                </div>
            </div>

            <!-- ── TEXT ── -->
            <div class="text-col">

                <div class="name-block">
                    <h1>Geo Rittenmyer</h1>
                    <p class="tagline">Seattle • Worldwide</p>
                </div>

                <div class="bio">
                    <p>
                        I'm a Seattle-based photographer and visual storyteller known for cinematic lighting, bold color, and carefully crafted imagery. With experience across studio, commercial, and location work, I approach each project with a clear creative vision and a collaborative mindset.
                    </p>
                    <p>
                        Over 20 years I've worked with some of the world's most recognizable brands — including Disney, NBC Universal, ESPN, Lyft, and Amazon — as well as major agencies, publications, and live productions nationwide. While I operate out of a fully equipped studio in Seattle, I can also build a studio environment almost anywhere in the world to meet the needs of a project.
                    </p>
                    <p>
                        I work closely with clients from the first conversation through final delivery, keeping the process straightforward, flexible, and enjoyable. I'm always happy to connect, talk through ideas, and collaborate on new work.
                    </p>
                </div>

                <div class="specialties">
                    <span>Advertising</span>
                    <span>Editorial</span>
                    <span>Sports</span>
                    <span>Brand</span>
                    <span>Portrait</span>
                    <span>Corporate</span>
                </div>

                <div class="contact-partners-row">
                    <div class="partners-col">
                        <div class="partner-item">
                            <span class="partner-label">Supported by</span>
                            <a href="https://wonderfulmachine.com" target="_blank" rel="noopener">
                                <img src="/images/Supported By Horizontal-Gray Trans.png" alt="Wonderful Machine" />
                            </a>
                        </div>
                        <div class="partner-item">
                            <span class="partner-label">Stock available via</span>
                            <a href="https://www.gallerystock.com" target="_blank" rel="noopener">
                                <img src="/images/GS-logo.png" alt="Gallery Stock" />
                            </a>
                        </div>
                    </div>
                </div>

                <div class="clients-block">
                    <p class="section-label">Selected Clients</p>
                    <p class="clients-list" id="clients-list" data-clients={JSON.stringify(clients)}></p>
                </div>

                <script>
                    const el = document.getElementById("clients-list");
                    const list: string[] = JSON.parse(el?.dataset.clients || "[]");

                    function shuffle() {
                        for (let i = list.length - 1; i > 0; i--) {
                            const j = Math.floor(Math.random() * (i + 1));
                            [list[i], list[j]] = [list[j], list[i]];
                        }
                        if (el) el.textContent = list.join(" · ");
                    }

                    shuffle();

                    el?.addEventListener("click", shuffle);
                </script>

            </div>
        </div>
    </div>

    <!-- ── Ask a Question Modal ── -->
    <div id="askModal" class="ask-modal" aria-hidden="true">
        <div class="ask-modal-body">
            <form id="askForm">
                <p class="ask-modal-title">Ask me anything</p>
                <input type="email" id="askEmail" name="from_email" placeholder="Your email" required />
                <textarea id="askQuestion" name="question" placeholder="What's on your mind?" rows="6" required></textarea>
                <div class="ask-modal-footer">
                    <button type="submit" id="askSubmit">Send</button>
                    <p class="ask-status" id="askStatus"></p>
                </div>
            </form>
        </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <script is:inline>
        // ── EmailJS config — fill these in ──
        var EMAILJS_PUBLIC_KEY  = "PiffeTcfIyUhjyYRA";
        var EMAILJS_SERVICE_ID  = "service_xwwm8io";
        var EMAILJS_TEMPLATE_ID = "template_5e8m7pt";

        var modal     = document.getElementById("askModal");
        var openBtn   = document.getElementById("askBtn");
        var form      = document.getElementById("askForm");
        var submitBtn = document.getElementById("askSubmit");
        var status    = document.getElementById("askStatus");

        function openAskModal() {
            modal.classList.add("open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
            document.getElementById("askEmail").focus();
        }

        function closeAskModal() {
            modal.classList.remove("open");
            modal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            form.reset();
            status.textContent = "";
            status.className = "ask-status";
        }

        openBtn.addEventListener("click", openAskModal);
        modal.addEventListener("click", function(e) {
            if (e.target === modal || e.target === modal.querySelector(".ask-modal-body")) closeAskModal();
        });
        document.addEventListener("keydown", function(e) {
            if (e.key === "Escape" && modal.classList.contains("open")) closeAskModal();
        });

        form.addEventListener("submit", async function(e) {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.textContent = "Sending…";
            status.textContent = "";

            try {
                emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });
                await emailjs.sendForm(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, form);
                status.textContent = "Sent! I'll get back to you soon.";
                status.className = "ask-status success";
                submitBtn.textContent = "Sent ✓";
                setTimeout(closeAskModal, 2000);
            } catch(err) {
                status.textContent = "Something went wrong — try emailing directly.";
                status.className = "ask-status error";
                submitBtn.disabled = false;
                submitBtn.textContent = "Send";
            }
        });
    </script>
</Base>

<style>
    .info-page {
        padding: calc(var(--nav-h) + 2%) 10% 6%;
        max-width: none;
        margin: 0;
    }

    /* ── Side-by-side layout ── */
    .layout {
        display: grid;
        grid-template-columns: minmax(0, 550px) 1fr;
        gap: 6%;
        align-items: start;
    }

    /* ── Photo ── */
    .photo-col {
        position: sticky;
        top: calc(var(--nav-h) + 24px);
        align-self: start;
    }

    .photo-wrap {
        position: relative;
        overflow: hidden;
        max-width: 550px;
    }

    .photo-wrap img {
        width: 100%;
        height: auto;
        display: block;
    }

    .photo-caption {
        font-size: 11px;
        color: var(--ink);
        letter-spacing: 0.05em;
        font-style: italic;
        margin: 12px 0 0 0;
        text-align: right;
    }

    .contact-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-top: 32px;
        max-width: 550px;
    }

    .ask-col {
        display: flex;
        align-items: flex-end;
    }

    /* ── Text column ── */
    .text-col {
        padding-top: 8px;
    }

    /* ── Name ── */
    .name-block {
        display: flex;
        align-items: baseline;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }

    h1 {
        font-family: cabin-sketch, sans-serif;
        font-size: clamp(28px, 3vw, 48px);
        font-weight: 400;
        letter-spacing: 0.02em;
        line-height: 1.1;
    }

    .tagline {
        font-size: 13px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-soft);
        white-space: nowrap;
    }

    /* ── Bio ── */
    .bio {
        margin-bottom: 32px;
    }

    .bio p {
        font-size: 17px;
        line-height: 1.8;
        color: var(--ink-soft);
        margin-bottom: 1.2em;
    }

    .bio a {
        color: var(--ink);
        border-bottom: 1px solid var(--accent);
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .bio a:hover { opacity: 0.65; }

    /* ── Specialty tags ── */
    .specialties {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 40px;
    }

    .specialties span {
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 5px 12px;
        border: 1px solid rgba(0, 0, 0, 0.15);
        color: var(--ink-soft);
    }

    /* ── Section label ── */
    .section-label {
        font-family: cabin-sketch, sans-serif;
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-bottom: 16px;
    }

    /* ── Contact + Partners row ── */
    .contact-partners-row {
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        padding-top: 32px;
        margin-bottom: 40px;
        display: flex;
        align-items: flex-start;
        gap: 48px;
        flex-wrap: wrap;
    }

    .contact-block {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-shrink: 0;
    }

    .contact-block a {
        font-size: 16px;
        text-decoration: none;
        color: var(--ink);
        transition: color 0.2s;
        width: fit-content;
    }
    .contact-block a:hover { color: var(--accent); }

    .available-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-soft);
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4caf50;
        flex-shrink: 0;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.35; }
    }

    /* ── Partners ── */
    .partners-col {
        display: flex;
        flex-direction: row;
        gap: 32px;
        align-items: flex-end;
        flex-wrap: wrap;
        padding-top: 30px;
    }

    .partner-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .partner-label {
        font-size: 12px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--ink-soft);
        opacity: 0.6;
    }

    .partners-col img {
        height: 56px;
        width: auto;
        opacity: 1;
        transition: opacity 0.2s;
        display: block;
    }

    .partners-col a:hover img {
        opacity: 0.45;
    }

    /* ── Clients ── */
    .clients-block {
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        padding-top: 32px;
    }

    .clients-list {
        font-size: 14px;
        line-height: 2;
        color: var(--ink-soft);
        letter-spacing: 0.04em;
    }

    /* ── Ask button ── */
    .ask-btn {
        margin-top: 0;
        padding: 12px 22px;
        font-family: cabin-sketch, sans-serif;
        font-size: 13px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--ink);
        background: transparent;
        border: 1px solid rgba(0, 0, 0, 0.2);
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
        width: fit-content;
    }
    .ask-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
    }

    /* ── Ask modal ── */
    .ask-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 600;
        background: rgba(240, 237, 229, 0.6);
        backdrop-filter: blur(4px);
        flex-direction: column;
    }
    .ask-modal.open {
        display: flex;
    }

    .ask-modal-title {
        font-family: cabin-sketch, sans-serif;
        font-size: 18px;
        letter-spacing: 0.06em;
        color: var(--ink);
        margin: 0;
    }

    .ask-modal-body {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
    }

    #askForm {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        max-width: 560px;
        background: var(--bg);
        padding: 20px;
        border: 1px solid rgba(0, 0, 0, 0.2);
    }

    #askForm input,
    #askForm textarea {
        width: 100%;
        padding: 14px 18px;
        font-family: sarala, sans-serif;
        font-size: 16px;
        color: var(--ink);
        background: transparent;
        border: 1px solid rgba(0, 0, 0, 0.15);
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
        resize: none;
    }
    #askForm input:focus,
    #askForm textarea:focus {
        border-color: var(--accent);
    }
    #askForm input::placeholder,
    #askForm textarea::placeholder {
        color: var(--ink-soft);
        opacity: 0.5;
    }

    .ask-modal-footer {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    #askSubmit {
        font-family: cabin-sketch, sans-serif;
        font-size: 11px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        padding: 12px 28px;
        background: var(--ink);
        color: var(--bg);
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
        flex-shrink: 0;
    }
    #askSubmit:hover { opacity: 0.75; }
    #askSubmit:disabled { opacity: 0.4; cursor: default; }

    .ask-status {
        font-size: 13px;
        color: var(--ink-soft);
    }
    .ask-status.success { color: #4caf50; }
    .ask-status.error   { color: #c0392b; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .layout {
            grid-template-columns: 1fr;
        }

        .photo-col {
            position: static;
        }

        .photo-wrap {
            max-width: 100%;
        }
    }
</style>
