  { id: 'enditall', title: 'End it All', images: ['1590546525397-STWHYERNIHOF3J6N0LVH/20200414_2558.jpg','1590546514092-NCTKTW76IQZ9K1XV82QY/20200414_2525.jpg','1590546536608-JQPXE7V2T0456F3Q3GIG/20200414_2594.jpg'] },
  { id: 'isolationcation', title: 'Isolation-cation', images: ['1590546908968-5P2U9PWCLAMVMM6GAW1G/20200411_1022.jpg','1590546891570-LP49B5X70XAC76OZ3EET/20200408_0334.jpg','1590546895676-ZG31QYTR2H3PYZU6HFZ0/20200408_0341.jpg','1590546913276-20UCMVHCX8CU153AMGUK/20200411_1027.jpg','1590546921396-9HWQF86ZGXKFFJ2QRM9P/20200411_1036.jpg'] },
  { id: 'digitalsnack', title: 'Digital Snack', images: ['1590547075984-BKGW5J6BHB73BODV8RE8/20200425_0073.jpg','1590547070993-UKSSXHMA7XBE9O7I5HCU/20200426_0226.jpg'] },
  { id: 'collections', title: 'Collections', images: ['1590547004053-D70MZ27H4FSL3GJ5CR79/20200423_0144_Temp.jpg','1590547006293-9NBUIMYUTML2FV39OOWZ/Coins_V1_1.jpg'] },
];

const projectData = projects.map(p => ({
  ...p,
  images: p.images.map(img => BASE + img),
  cover: BASE + p.images[0],
}));
---

<Base title="COVID-19 Projects — Geo Rittenmyer">
  <div class="masonry" id="covidGrid">
    {projectData.map((p, i) => (
      <div class="card" style={`animation-delay: ${i * 40}ms`} data-images={JSON.stringify(p.images)} data-title={p.title}>
        <img src={p.cover} alt={p.title} loading={i < 4 ? 'eager' : 'lazy'} />
        <div class="card-label"><span>{p.title}</span></div>
      </div>
    ))}
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('.card').forEach(card => {
    const images: string[] = JSON.parse(card.dataset.images || '[]');
    if (images.length > 1) {
      const img = card.querySelector('img') as HTMLImageElement;
      img.src = images[Math.floor(Math.random() * images.length)];
    }
  });
</script>
