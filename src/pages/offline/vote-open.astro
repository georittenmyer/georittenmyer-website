---
import Base from '../../layouts/Base.astro';

const BASE = 'https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/';

const projects = [
  { id: 'votersguide', title: 'Voters Guide', images: ['1591728605720-OM6V5P7FT72CHWRMFXX5/VotersGuide.png'] },
  { id: 'baker', title: 'Baker', images: ['1591728688739-FG5PVB7M38W5AN9NYM0H/Baker.jpg'] },
  { id: 'bea', title: 'Bea', images: ['1591728688885-MR22S8JSN5IPDQ9GWXSX/Bea.jpg'] },
  { id: 'benji', title: 'Benji', images: ['1591728693678-S1ENLNHUPH6VCVTQ4OZP/Benji.jpg'] },
  { id: 'irwin', title: 'Irwin', images: ['1591728692292-2AE6X1V9YL2E13VL0G1T/Irwin.jpg'] },
  { id: 'parker', title: 'Parker', images: ['1591728696626-I7Y4NC8K8UG1ZF60CSWS/Parker.jpg'] },
  { id: 'wells', title: 'Wells', images: ['1591728697101-C7LIDVFE1A2Q76W3HLG9/Wells.jpg'] },
];

const projectData = projects.map(p => ({
  ...p,
  images: p.images.map(img => BASE + img),
  cover: BASE + p.images[0],
}));
---

<Base title="Vote Open — Geo Rittenmyer">
  <div class="masonry" id="voteGrid">
    {projectData.map((p, i) => (
      <div class="card" style={`animation-delay: ${i * 40}ms`} data-images={JSON.stringify(p.images)} data-title={p.title}>
        <img src={p.cover} alt={p.title} loading="eager" />
        <div class="card-label"><span>{p.title}</span></div>
      </div>
    ))}
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>('.card').forEach(card => {
    const images: string[] = JSON.parse(card.dataset.images || '[]');
    if (images.length > 1) {
      const img = card.querySelector('img') as HTMLImageElement;
      img.src = images[Math.floor(Math.random() * images.length)];
    }
  });
</script>
