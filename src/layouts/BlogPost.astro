---
import Base from "./Base.astro";

export interface Props {
    title: string;
    date: string;
    description: string;
    cover: string;
    images?: string[];
    columns?: number;
}

const { title, date, description, cover, images = [], columns = 3 } = Astro.props.frontmatter ?? Astro.props;

const formatted = new Date(String(date).replace(/-/g, '/')).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

// Next post (chronologically newer)
const allPosts = await Astro.glob('../pages/blog/*.md');
const sorted = allPosts.sort((a, b) =>
    new Date(a.frontmatter.date).getTime() - new Date(b.frontmatter.date).getTime()
);
const currentIndex = sorted.findIndex(p => p.frontmatter.date === date && p.frontmatter.title === title);
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description: description,
    image: cover,
    datePublished: date,
    author: {
        "@type": "Person",
        name: "Geo Rittenmyer",
        url: "https://georittenmyer.com",
    },
    publisher: {
        "@type": "Person",
        name: "Geo Rittenmyer",
    },
});
---

<Base
    title={`${title} — Geo Rittenmyer`}
    description={description}
    ogImage={cover}
>
    <script type="application/ld+json" set:html={jsonLd} slot="head" />

    <article class="post">
        <header class="post-header">
            <div class="post-nav">
                <a href="/blog" class="back-link">← All Posts</a>
                {nextPost && (
                    <a href={nextPost.url} class="next-link">{nextPost.frontmatter.title} →</a>
                )}
            </div>
            <h1>{title}</h1>
            <time datetime={date}>{formatted}</time>
            {description && <p class="post-desc">{description}</p>}
        </header>

        <div class="post-body">
            <slot />
        </div>

        {images.length > 0 && (
            <div class="post-photos" style={`--cols: ${columns}`}>
                {images.map((src, i) => (
                    <div class="photo-item" data-src={src}>
                        <img src={src} alt={`${title} ${i + 1}`} loading={i < 6 ? 'eager' : 'lazy'} />
                    </div>
                ))}
            </div>
        )}
    </article>

    <!-- Zoom overlay -->
    <div id="zoom-overlay" aria-hidden="true">
        <button id="zoom-close" class="lb-key-btn" aria-label="Close">ESC</button>
        <button id="zoom-prev" class="lb-key-btn" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 4 6 9 11 14"/></svg>
        </button>
        <button id="zoom-next" class="lb-key-btn" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 4 12 9 7 14"/></svg>
        </button>
        <div class="zoom-wrap">
            <img id="zoom-img" src="" alt="" />
        </div>
        <div id="zoom-counter"></div>
    </div>
</Base>

<script is:inline>
(function() {
    const overlay = document.getElementById('zoom-overlay');
    const zoomImg = document.getElementById('zoom-img');
    const closeBtn = document.getElementById('zoom-close');
    const prevBtn = document.getElementById('zoom-prev');
    const nextBtn = document.getElementById('zoom-next');
    const counter = document.getElementById('zoom-counter');
    const items = Array.from(document.querySelectorAll('.photo-item'));
    let current = 0;

    function open(index) {
        current = index;
        zoomImg.src = items[current].dataset.src;
        counter.textContent = (current + 1) + ' / ' + items.length;
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function close() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    function prev() {
        current = (current - 1 + items.length) % items.length;
        zoomImg.src = items[current].dataset.src;
        counter.textContent = (current + 1) + ' / ' + items.length;
    }

    function next() {
        current = (current + 1) % items.length;
        zoomImg.src = items[current].dataset.src;
        counter.textContent = (current + 1) + ' / ' + items.length;
    }

    items.forEach((item, i) => item.addEventListener('click', () => open(i)));
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);
    overlay.addEventListener('click', (e) => { if (e.target === overlay || e.target.classList.contains('zoom-wrap')) close(); });

    document.addEventListener('keydown', (e) => {
        if (!overlay.classList.contains('active')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') prev();
        if (e.key === 'ArrowRight') next();
    });
})();
</script>

<style>
    .post {
        max-width: 1500px;
        margin: 0 auto;
        padding: calc(var(--nav-h) + 48px) 32px 80px;
    }

    .post-header { margin-bottom: 40px; }

    .post-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .back-link, .next-link {
        display: inline-block;
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-soft);
        text-decoration: none;
        transition: color 0.2s;
    }
    .back-link:hover, .next-link:hover { color: var(--ink); }

    h1 {
        font-size: clamp(32px, 6vw, 64px);
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin-bottom: 12px;
    }

    time {
        display: block;
        font-size: 13px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-bottom: 16px;
    }

    .post-desc { display: none; }

    /* ── Post body ── */
    .post-body {
        font-size: 20px;
        line-height: 1.75;
        color: var(--ink);
    }

    .post-body :global(p) { margin-bottom: 1.5em; }

    .post-body :global(h2) {
        font-size: 28px;
        font-weight: 300;
        letter-spacing: 0.02em;
        margin: 2.5em 0 0.75em;
    }

    .post-body :global(h3) {
        font-size: 22px;
        font-weight: 300;
        margin: 2em 0 0.5em;
    }

    .post-body :global(blockquote) {
        border-left: 2px solid var(--accent);
        padding-left: 20px;
        font-style: italic;
        color: var(--ink-soft);
        margin: 2em 0;
    }

    .post-body :global(a) {
        color: var(--ink);
        border-bottom: 1px solid var(--accent);
        text-decoration: none;
        transition: border-color 0.2s;
    }
    .post-body :global(a:hover) { border-color: var(--ink); }

    /* ── Photo grid ── */
    .post-photos {
        margin: 60px 0 0;
        columns: var(--cols, 3);
        column-gap: 12px;
    }

    .photo-item {
        break-inside: avoid;
        margin-bottom: 12px;
        overflow: hidden;
        cursor: pointer;
    }

    .photo-item img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .photo-item:hover img { transform: scale(1.03); }

    /* ── Zoom overlay ── */
    #zoom-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--bg);
        z-index: 600;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    #zoom-overlay.active { display: flex; }

    .zoom-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        padding: 120px;
        box-sizing: border-box;
    }

    #zoom-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
        user-select: none;
    }

    #zoom-close {
        position: absolute;
        top: 24px;
        left: 6%;
        font-family: sarala, sans-serif;
        font-size: 13px;
        letter-spacing: 0.12em;
        padding: 7px 12px;
        z-index: 601;
    }

    #zoom-prev, #zoom-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        padding: 12px;
        z-index: 601;
    }
    #zoom-prev:hover, #zoom-next:hover {
        transform: translateY(calc(-50% + 0.3px));
    }
    #zoom-prev { left: 32px; }
    #zoom-next { right: 32px; }

    #zoom-counter {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        font-family: sketchnote-square, sans-serif;
        font-size: 13px;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
    }

    @media (max-width: 900px) {
        .post-photos { columns: 2; }
    }

    @media (max-width: 640px) {
        .post { padding: 32px 20px 60px; }
        .post-photos { columns: 1; }
        .zoom-wrap { padding: 80px 24px; }
        #zoom-prev { left: 12px; }
        #zoom-next { right: 12px; }
    }
</style>
