---
export interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

const {
    title,
    description = "Seattle-based photographer Geo Rittenmyer — documentary and commercial work.",
    ogImage = "/images/og-default.jpg",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(ogImage, Astro.site)} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <link rel="stylesheet" href="https://use.typekit.net/kgj2dsh.css" />
        <link rel="stylesheet" href="/src/styles/global.css" />
        <slot name="head" />
    </head>
    <body>
        <nav>
            <div class="nav-left">
                <ul class="nav-links">
                    <li>
                        <a
                            href="/"
                            aria-current={Astro.url.pathname === "/"
                                ? "page"
                                : undefined}>The Work</a
                        >
                    </li>
                    <li>
                        <a
                            href="/info"
                            aria-current={Astro.url.pathname === "/info"
                                ? "page"
                                : undefined}>Info</a
                        >
                    </li>
                    <li>
                        <a
                            href="/blog"
                            aria-current={Astro.url.pathname.startsWith("/blog")
                                ? "page"
                                : undefined}>Blog</a
                        >
                    </li>
                </ul>
            </div>
            <a class="nav-logo" href="/">
                <img
                    src="https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/d646a719-cf1d-4c64-9548-decdf8041fe9/Logo_Left_Default.png?format=300w"
                    alt="Geo Rittenmyer"
                />
            </a>
            <div class="nav-right">
                <a
                    class="nav-instagram"
                    href="https://www.instagram.com/georittenmyer/"
                    target="_blank"
                    rel="noopener"
                    aria-label="Instagram"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                        ></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle
                            cx="17.5"
                            cy="6.5"
                            r="0.5"
                            fill="currentColor"
                            stroke="none"></circle>
                    </svg>
                </a>
                <button class="burger" id="burgerBtn" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </nav>

        <div class="mobile-menu" id="mobileMenu">
            <a href="/">The Work</a>
            <a href="/info">Info</a>
            <a href="/blog">Blog</a>
        </div>

        <main>
            <slot />
        </main>

        <footer>
            <div class="footer-inner">
                <div class="footer-col">
                    <p class="footer-label">Connect</p>
                    <a href="mailto:geo@georittenmyer.com">Email Me</a>
                    <a
                        href="https://wa.me/6465849860"
                        target="_blank"
                        rel="noopener">Hi on WhatsApp</a
                    >
                    <a
                        href="https://www.linkedin.com/in/georittenmyer/"
                        target="_blank"
                        rel="noopener">LinkedIn</a
                    >
                </div>
                <div class="footer-col">
                    <p class="footer-label">More</p>
                    <a href="/archive">Archive</a>
                    <a href="/kodachrome">Kodachrome</a>
                    <a
                        href="https://client.georittenmyer.com"
                        target="_blank"
                        rel="noopener">Client Access</a
                    >
                </div>
                <div class="footer-col">
                    <p class="footer-label">Extra</p>
                    <a
                        href="https://crittenmyer.com"
                        target="_blank"
                        rel="noopener">Chelsea!</a
                    >
                    <span>Design by RFI</span>
                    <span>© Geo Rittenmyer — All Rights Reserved</span>
                </div>
            </div>
        </footer>

        <!-- Lightbox -->
        <div id="lightbox" class="lightbox" aria-hidden="true">
            <div class="lb-header">
                <span class="lb-title" id="lb-title"></span>
                <button class="lb-close lb-key-btn" aria-label="Close"
                    >ESC</button
                >
            </div>
            <div class="lb-grid" id="lb-grid"></div>
            <!-- Single image zoom view -->
            <div class="lb-zoom" id="lb-zoom">
                <button
                    class="lb-zoom-close lb-key-btn"
                    aria-label="Back to grid">ESC</button
                >
                <button class="lb-prev lb-key-btn" aria-label="Previous">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 18 18"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><polyline points="11 4 6 9 11 14"></polyline></svg
                    >
                </button>
                <button class="lb-next lb-key-btn" aria-label="Next">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 18 18"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><polyline points="7 4 12 9 7 14"></polyline></svg
                    >
                </button>
                <div class="lb-zoom-wrap">
                    <img id="lb-zoom-img" src="" alt="" />
                </div>
                <div class="lb-counter" id="lb-counter"></div>
            </div>
        </div>

        <script>
            // Burger menu
            const burger = document.getElementById("burgerBtn");
            const menu = document.getElementById("mobileMenu");
            burger?.addEventListener("click", () => {
                burger.classList.toggle("open");
                menu?.classList.toggle("open");
            });

            // Lightbox
            const lightbox = document.getElementById("lightbox")!;
            const lbGrid = document.getElementById("lb-grid")!;
            const lbTitle = document.getElementById("lb-title")!;
            const lbZoom = document.getElementById("lb-zoom")!;
            const lbZoomImg = document.getElementById(
                "lb-zoom-img",
            ) as HTMLImageElement;
            const lbCounter = document.getElementById("lb-counter")!;
            const lbClose = lightbox.querySelector(
                ".lb-close",
            ) as HTMLButtonElement;
            const lbZoomClose = lightbox.querySelector(
                ".lb-zoom-close",
            ) as HTMLButtonElement;
            const lbPrev = lightbox.querySelector(
                ".lb-prev",
            ) as HTMLButtonElement;
            const lbNext = lightbox.querySelector(
                ".lb-next",
            ) as HTMLButtonElement;

            let images: string[] = [];
            let current = 0;

            function openLightbox(imgs: string[], title: string) {
                images = imgs;
                lbTitle.textContent = title;
                // Build grid
                lbGrid.innerHTML = "";
                imgs.forEach((src, i) => {
                    const img = document.createElement("img");
                    img.src = src;
                    img.alt = title;
                    img.loading = "lazy";
                    img.addEventListener("click", () => openZoom(i));
                    lbGrid.appendChild(img);
                });
                lbZoom.classList.remove("open");
                lightbox.classList.add("open");
                lightbox.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
            }

            function closeLightbox() {
                lightbox.classList.remove("open");
                lightbox.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
                lbZoom.classList.remove("open");
            }

            function openZoom(index: number) {
                current = index;
                showZoom();
                lbZoom.classList.add("open");
            }

            function showZoom() {
                lbZoomImg.src = images[current];
                lbCounter.textContent = `${current + 1} / ${images.length}`;
            }

            lbPrev.addEventListener("click", () => {
                current = (current - 1 + images.length) % images.length;
                showZoom();
            });
            lbNext.addEventListener("click", () => {
                current = (current + 1) % images.length;
                showZoom();
            });
            lbClose.addEventListener("click", closeLightbox);
            lbZoomClose.addEventListener("click", () =>
                lbZoom.classList.remove("open"),
            );

            // Click backdrop to close (except on images or buttons)
            lightbox.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                if (
                    target === lightbox ||
                    (!target.closest("img") && !target.closest("button"))
                ) {
                    closeLightbox();
                }
            });
            lbZoom.addEventListener("click", (e) => {
                if (
                    e.target === lbZoom ||
                    (e.target as HTMLElement).classList.contains("lb-zoom-wrap")
                ) {
                    lbZoom.classList.remove("open");
                }
            });

            document.addEventListener("keydown", (e) => {
                if (!lightbox.classList.contains("open")) return;
                if (e.key === "Escape") {
                    if (lbZoom.classList.contains("open"))
                        lbZoom.classList.remove("open");
                    else closeLightbox();
                }
                if (!lbZoom.classList.contains("open")) return;
                if (e.key === "ArrowLeft") {
                    current = (current - 1 + images.length) % images.length;
                    showZoom();
                }
                if (e.key === "ArrowRight") {
                    current = (current + 1) % images.length;
                    showZoom();
                }
            });

            // Open lightbox on card click (only div cards with data-images, not <a> link cards)
            document.addEventListener("click", (e) => {
                const card = (e.target as HTMLElement).closest(".card");
                if (
                    !card ||
                    card.tagName === "A" ||
                    !card.hasAttribute("data-images")
                )
                    return;
                e.preventDefault();
                const imgs: string[] = JSON.parse(
                    card.getAttribute("data-images") || "[]",
                );
                const title = card.getAttribute("data-title") || "";
                if (imgs.length === 0) return;
                openLightbox(imgs, title);
            });
        </script>
    </body>
</html>
