---
export interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

const {
    title,
    description = "Seattle-based photographer Geo Rittenmyer — documentary and commercial work.",
    ogImage = "/images/og-default.jpg",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(ogImage, Astro.site)} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <link rel="stylesheet" href="https://use.typekit.net/kgj2dsh.css" />
        <link rel="stylesheet" href="/src/styles/global.css" />
        <slot name="head" />
    </head>
    <body>
        <nav>
            <div class="nav-left">
                <ul class="nav-links">
                    <li>
                        <a
                            href="/"
                            aria-current={Astro.url.pathname === "/"
                                ? "page"
                                : undefined}>The Work</a
                        >
                    </li>
                    <li>
                        <a
                            href="/info"
                            aria-current={Astro.url.pathname === "/info"
                                ? "page"
                                : undefined}>Info</a
                        >
                    </li>
                    <li>
                        <a
                            href="/blog"
                            aria-current={Astro.url.pathname.startsWith("/blog")
                                ? "page"
                                : undefined}>Blog</a
                        >
                    </li>
                </ul>
            </div>
            <a class="nav-logo" href="/">
                <img
                    src="https://images.squarespace-cdn.com/content/v1/50c4bd4be4b0112a45d7e1e2/d646a719-cf1d-4c64-9548-decdf8041fe9/Logo_Left_Default.png?format=300w"
                    alt="Geo Rittenmyer"
                />
            </a>
            <div class="nav-right">
                <a
                    class="nav-instagram"
                    href="https://www.instagram.com/georittenmyer/"
                    target="_blank"
                    rel="noopener"
                    aria-label="Instagram"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                        ></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle
                            cx="17.5"
                            cy="6.5"
                            r="0.5"
                            fill="currentColor"
                            stroke="none"></circle>
                    </svg>
                </a>
                <button class="burger" id="burgerBtn" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </nav>

        <div class="mobile-menu" id="mobileMenu">
            <a href="/">The Work</a>
            <a href="/info">Info</a>
            <a href="/blog">Blog</a>
        </div>

        <main>
            <slot />
        </main>

        <footer>
            <div class="footer-inner">
                <div class="footer-col">
                    <p class="footer-label">Connect</p>
                    <a href="mailto:hello@georittenmyer.com">hello@georittenmyer.com</a>
                    <a href="https://wa.me/6465849860" target="_blank" rel="noopener">Chat on WhatsApp</a>
                    <a href="https://www.linkedin.com/in/georittenmyer/" target="_blank" rel="noopener">LinkedIn</a>
                </div>
                <div class="footer-col">
                    <p class="footer-label">More</p>
                    <a href="https://client.georittenmyer.com" target="_blank" rel="noopener">Client Access</a>
                    <a href="#" aria-disabled="true">Travels</a>
                    <a href="#" aria-disabled="true">Archive</a>
                </div>
                <div class="footer-col">
                    <p class="footer-label">Legal</p>
                    <a href="#" aria-disabled="true">Privacy Statement</a>
                    <span>© Geo Rittenmyer — All Rights Reserved</span>
                </div>
                <div class="footer-col">
                    <p class="footer-label">Friends</p>
                    <a href="https://crittenmyer.com" target="_blank" rel="noopener">Chelsea</a>
                    <span>Design by Rat Face Industries</span>
                </div>
            </div>
        </footer>

        <script>
            const burger = document.getElementById("burgerBtn");
            const menu = document.getElementById("mobileMenu");
            burger?.addEventListener("click", () => {
                burger.classList.toggle("open");
                menu?.classList.toggle("open");
            });
        </script>
    </body>
</html>
